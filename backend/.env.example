# PageStruct AI local environment example
# Copy this file to backend/.env or project-root .env, then fill in your values.

# App
APP_NAME=PageStruct AI
DEBUG=true

# LLM provider
# The service expects an OpenAI-compatible Chat Completions API.
LLM_API_KEY=sk-your-api-key-here
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=60

# Example for a local OpenAI-compatible server:
# LLM_API_KEY=local-dev-key
# LLM_API_URL=http://127.0.0.1:8001/v1/chat/completions
# LLM_MODEL=your-local-model-name
# LLM_TIMEOUT=120
